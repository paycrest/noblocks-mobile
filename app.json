{
  "expo": {
    "name": "noblocks",
    "slug": "noblocks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "noblocks",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paycrest.noblocks",
      "associatedDomains": [
        "webcredentials:roosta-landing-page.vercel.app"
      ],
      "appleTeamId": "5RHBQ5CR25"
    },
    "extra": {
      "passkeyAssociatedDomain": "https://roosta-landing-page.vercel.app",
      "privyAppId": "cmfgv67190088jx0bl9boahgl",
      "privyClientId": "client-WY6QhUcguZYygmFFCzRW8kqCjPeT9XkDWS6UwxKHKxYnV",
      "router": {},
      "eas": {
        "projectId": "56cc359e-330a-4cec-acc7-e4ce6bc71e3b"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.paycrest.noblocks",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID."
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "extraPods": [
              { "name": "SmileID", "modular_headers": true },
              { "name": "SmileIDSDK", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "paycrest-dev",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/56cc359e-330a-4cec-acc7-e4ce6bc71e3b"
    }
  }
}
