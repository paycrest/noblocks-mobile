# Copy this file to .env (and/or .env.development, .env.staging, .env.production)
# and fill in the real values. Never commit a populated env file.
#
# Anything prefixed with EXPO_PUBLIC_ is inlined into the JS bundle at build time
# and is therefore visible to anyone who downloads the app. Do not put true
# server-only secrets here.

# Which environment this build represents. Set automatically by EAS profiles;
# override locally if you want runtime branching.
EXPO_PUBLIC_APP_ENV=development

# --- Paycrest API ------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=https://api.paycrest.io/v2
EXPO_PUBLIC_API_KEY=

# --- Privy -------------------------------------------------------------------
EXPO_PUBLIC_PRIVY_BASE_URL=https://api.privy.io/v1
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=
EXPO_PUBLIC_PRIVY_APP_SECRET=
